{
  "manifest_version": 3,
  "name": "AA Copy Tool",
  "version": "0.1.0",
  "description": "AAを検索・ストック・コピーするChrome拡張",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "activeTab", "tabs", "clipboardWrite"],
  "host_permissions": [
    "https://aa-copy-tool-goroyattemiyos-projects.vercel.app/*",
    "https://aahub.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://aahub.org/*"],
      "js": ["content_aahub.js"]
    }
  ]
}
